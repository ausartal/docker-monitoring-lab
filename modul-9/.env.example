# Salin file ini ke .env dan isi dengan nilai sebenarnya
# cp .env.example .env

# Generate: openssl rand -hex 16
DRONE_RPC_SECRET=isi_dengan_hasil_openssl_rand_hex_16

# Didapat dari Gitea: Settings > Applications > Manage OAuth2 Applications
DRONE_GITEA_CLIENT_ID=isi_dari_gitea_oauth_app
DRONE_GITEA_CLIENT_SECRET=isi_dari_gitea_oauth_app
